# Flask
SECRET_KEY=change-me-in-production-use-long-random-string
FLASK_ENV=production
FLASK_DEBUG=0

# Database
DATABASE_URL=postgresql://ticketing_user:strongpassword@db:5432/ticketing_db

# Microsoft 365 / Graph API (for email-to-ticket)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
O365_MAILBOX=informatics@intermedic.com

# Outbound mail (SMTP via O365)
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=informatics@intermedic.com
MAIL_PASSWORD=your-smtp-app-password
MAIL_DEFAULT_SENDER=informatics@intermedic.com

# App settings
APP_BASE_URL=https://support.intermedic.com
ITEMS_PER_PAGE=25
EMAIL_POLL_INTERVAL_SECONDS=60
